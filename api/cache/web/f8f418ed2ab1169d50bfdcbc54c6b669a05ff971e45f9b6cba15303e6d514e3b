    "html" :
    
    
    "<b>What is a software system?</b>"
    
    }
    
    }
    
    ]
    
    }
    
    }
    ,
    
    {
    
    
    "type" :
    
    
    "static"
    ,
    
    "inputs" : {
    
    
    "para" :
    true,
    
    "html" :
    
    
    "A software system includes all software and hardware versions of the various control units in a vehicle and their approved combinations."
    
    }
    
