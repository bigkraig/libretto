    ,
    
    "inputs" : {
    
    
    "html" :
    
    
    "<b>What is a system release (SR)?</b>"
    
    }
    
    }
    
    ]
    
    }
    
    }
    ,
    
    {
    
    
    "type" :
    
    
    "static"
    ,
    
    "inputs" : {
    
    
    "para" :
    true,
    
    "html" :
    
    
    "A system release (SR) describes a system that is released with a certain technical status."
    
    }
    
    }
    ,
    
    {
    
    
    "type" :
    
    
    "list"
    ,
    
    "inputs" : {
    
    
