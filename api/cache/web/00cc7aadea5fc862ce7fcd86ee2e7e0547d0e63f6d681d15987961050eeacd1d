    "consequences" : [
    
    
    
    "The bonding surfaces must be free from oil, dirt, moisture, and paint and oxide layers."
    ,
    
    
    "If the bonding surface is exposed for more than 2 hours, or if it is dirty, it must be cleaned using isopropanol."
    ,
    
    
    "Use clean, lint-free disposable cloths to clean the surfaces."
    
    ]
